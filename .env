# -----------------------------------------------------------------------------
# Firebase Admin SDK (Server-Side)
# Used for server-side actions like processing webhooks and checking usage.
# -----------------------------------------------------------------------------
# Get this by going to Firebase > Project Settings > Service Accounts > Generate new private key
# Then, Base64 encode the entire contents of the downloaded JSON file.
FIREBASE_SERVICE_ACCOUNT_KEY_BASE64=

# -----------------------------------------------------------------------------
# Firebase Client SDK (Client-Side)
# These are safe to be public and are used by the browser to connect to Firebase.
# -----------------------------------------------------------------------------
# Get these from Firebase > Project Settings > General > Your apps > Web app
GOOGLE_GENAI_API_KEY=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
GEMINI_API_KEY=
NEWS_API_AI_KEY=
PADDLE_WEBHOOK_SECRET_KEY=

# -----------------------------------------------------------------------------
# Third-Party API Keys (Server-Side)
# -----------------------------------------------------------------------------
# Get this from NewsAPI.ai (Event Registry) for news search
NEWS_API_AI_KEY=
# Get these from your Twitter/X Developer account for tweet search
TWITTER_API_KEY=
TWITTER_API_KEY_SECRET=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
