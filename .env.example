# Genkit/Google AI
# Get your key from Google AI Studio: https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=

# News API (from newsapi.ai / Event Registry)
# Optional: for live news in research. Get a key from https://newsapi.ai/
NEWS_API_AI_KEY=

# Twitter/X API v2
# Optional: for live Twitter search in research. Get keys from https://developer.twitter.com/
TWITTER_API_KEY=
TWITTER_API_KEY_SECRET=

# Firebase - These are for the client-side
# Get these from your Firebase project settings
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
