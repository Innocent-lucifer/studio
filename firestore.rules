rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read, update, or delete their own document.
    // They can also create their own document upon sign-up.
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Users can manage their own drafts subcollection.
    match /users/{userId}/drafts/{draftId} {
      allow read, write, create, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Users can manage their own campaignDrafts subcollection.
    match /users/{userId}/campaignDrafts/{campaignDraftId} {
        allow read, write, create, delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
